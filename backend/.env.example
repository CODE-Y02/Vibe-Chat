# ── Application ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Redis (Optional — set USE_REDIS=false to use in-memory fallback) ──────────
USE_REDIS=false
REDIS_URL=redis://localhost:6379

# ── Database (Supabase Postgres) ───────────────────────────────────────────────
# Use the direct connection string from: Supabase Dashboard → Settings → Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres?schema=public

# ── Supabase Auth ──────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[YOUR-PROJECT-ID].supabase.co
SUPABASE_ANON_KEY=your-publishable-anon-key-here

# ── Webhook Security ───────────────────────────────────────────────────────────
# A secret you create yourself — set the same value in Supabase Dashboard → Database → Webhooks
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-here

# ── Service-to-Service ─────────────────────────────────────────────────────────
S2S_API_KEY=your-s2s-key-here

# ── Features ───────────────────────────────────────────────────────────────────
USE_CLUSTER=false
